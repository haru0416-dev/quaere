{
  "name": "quaere-cli",
  "version": "0.3.2",
  "description": "Install Quaere process-correction skills for Claude Code and Codex",
  "type": "module",
  "bin": {
    "quaere-cli": "dist/cli.mjs",
    "quaere": "dist/cli.mjs"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "oxlint": "^1.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "claude-code",
    "codex",
    "skills",
    "coding-agent",
    "quaere"
  ],
  "author": "Haru",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/haru0416-dev/quaere"
  },
  "homepage": "https://quaere.dev",
  "packageManager": "pnpm@9.15.0"
}
